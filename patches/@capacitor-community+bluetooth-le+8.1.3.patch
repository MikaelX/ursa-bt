+    /// Advertised local name (often present when `peripheral.name` is still nil during scan).
+    private func effectivePeripheralName(peripheral: CBPeripheral, advertisementData: [String: Any]) -> String? {
+        if let local = advertisementData[CBAdvertisementDataLocalNameKey] as? String {
+            let t = local.trimmingCharacters(in: .whitespacesAndNewlines)
+            if !t.isEmpty { return t }
+        }
+        if let n = peripheral.name {
+            let t = n.trimmingCharacters(in: .whitespacesAndNewlines)
+            if !t.isEmpty { return t }
+        }
+        return nil
+    }
+
+    /// Picker row when the peripheral is linked on this phone (no fresh advertisement).
+    private func connectedPickerRowLabel(peripheral: CBPeripheral, advertisementData: [String: Any]) -> String {
+        if let name = effectivePeripheralName(peripheral: peripheral, advertisementData: advertisementData) {
+            return "\(name) · on this phone"
+        }
+        let id = peripheral.identifier.uuidString
+        let tail = id.split(separator: "-").last.map(String.init) ?? String(id.suffix(8))
+        return "Bluetooth device · \(tail) · on this phone — tap"
+    }
+
+    private func scannerListLabel(peripheral: CBPeripheral, advertisementData: [String: Any], rssi: NSNumber) -> String {
