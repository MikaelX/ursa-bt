{
  "name": "bm-bluetooth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "npm-run-all --parallel dev dev:server",
    "build": "tsc --noEmit && vite build",
    "build:cap": "CAPACITOR_BUILD=1 ENVIRONMENT=production npm run build && npx cap sync",
    "ios:sync": "CAPACITOR_BUILD=1 ENVIRONMENT=production npm run build && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "ios:archive": "bash scripts/ios-archive.sh",
    "ios:export": "bash scripts/ios-export-ipa.sh",
    "android:release": "bash scripts/android-release.sh",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "atem:ccu-watch": "tsx scripts/atem-ccu-watch.ts",
    "atem:send-video-gain": "tsx scripts/atem-send-video-gain.ts",
    "atem:ccu-watch:log": "bash scripts/atem-ccu-watch-log.sh",
    "atem:analyze-log": "tsx scripts/analyze-atem-log.ts",
    "test:e2e:atem-ccu": "tsx scripts/e2e-atem-ccu-relay.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@atem-connection/camera-control": "^0.4.0",
    "@capacitor-community/bluetooth-le": "^8.1.3",
    "@capacitor/core": "^8.3.1",
    "atem-connection": "^3.9.0",
    "ioredis": "^5.10.1",
    "tsx": "^4.20.6",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@fontsource/dseg7-classic": "^5.2.5",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "patch-package": "^8.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
