{
  "name": "bm-bluetooth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "dev:all": "npm-run-all --parallel dev dev:server",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@fontsource/dseg7-classic": "^5.2.5",
    "@types/node": "^25.6.0",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
