+    private func seedLeScanWithRetrieveConnectedPeripherals(forServiceHints hints: [CBUUID]) {
+        guard self.deviceListMode == .none else { return }
+        guard hints.isEmpty == false else { return }
+        guard let scanCb = self.scanResultCallback else { return }
+
+        let emptyAdv = [String: Any]()
+        let synthRssi = NSNumber(value: 0)
+
+        for peripheral in centralManager.retrieveConnectedPeripherals(withServices: hints) {
+            guard peripheral.state == CBPeripheralState.connected else { continue }
+
+            let filterName = effectivePeripheralName(peripheral: peripheral, advertisementData: emptyAdv)
+            guard self.passesNameFilter(peripheralName: filterName) else { continue }
+            guard self.passesNamePrefixFilter(peripheralName: filterName) else { continue }
+            guard ScanFilterUtils.passesManufacturerDataFilter(emptyAdv, filters: self.manufacturerDataFilters) else { continue }
+            guard ScanFilterUtils.passesServiceDataFilter(emptyAdv, filters: self.serviceDataFilters) else { continue }
+
+            let deviceId = peripheral.identifier.uuidString
+            let isNew = self.discoveredPeripherals[deviceId] == nil
+            self.discoveredPeripherals[deviceId] = peripheral
+
+            let listLabel = rowLabelForPicker(peripheral: peripheral, advertisementData: emptyAdv, rssi: synthRssi)
+            if isNew || self.allowDuplicates {
+                log("LE scan seeded connected peripheral: ", listLabel)
+                scanCb(peripheral, emptyAdv, synthRssi)
+            }
+        }
+    }
