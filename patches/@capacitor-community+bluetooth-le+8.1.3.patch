+    /// Union scan `services` + `optionalServices` for `retrieveConnectedPeripherals` hints (JS lists BM GATT under optional on broad scans).
+    private static func mergedRetrieveHintUuids(scan: [CBUUID], optional: [CBUUID]) -> [CBUUID] {
+        var seen = Set<String>()
+        var out: [CBUUID] = []
+        for u in scan + optional {
+            let key = u.uuidString.lowercased()
+            if seen.insert(key).inserted {
+                out.append(u)
+            }
+        }
+        return out
+    }
