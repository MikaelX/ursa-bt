+            return name
+        }
+        let id = peripheral.identifier.uuidString
+        let tail = id.split(separator: "-").last.map(String.init) ?? String(id.suffix(8))
+        return "Unknown · \(tail) · \(rssi.intValue) dBm"
+    }
